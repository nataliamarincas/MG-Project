    notas: document.getElementById('f-notas').value||'Ninguna'
  };
}

// ── GENERATE PLAN ──
async function generarPlan(){
  const d=getFormData();
  const btn=document.getElementById('btn-generar');
  const wrap=document.getElementById('output-wrap');
  const body=document.getElementById('output-body');
  const loading=document.getElementById('output-loading');
  const title=document.getElementById('output-title');

  btn.disabled=true;btn.textContent='Generando...';
  wrap.style.display='block';
  loading.style.display='block';
  title.textContent=`Plan personalizado — ${d.nombre}`;
  body.innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:200px;gap:16px;color:rgba(255,255,255,.4)">
    <div class="loading-dots"><span></span><span></span><span></span></div>
    <div style="font-size:11px">Analizando perfil y generando plan con IA...</div>
  </div>`;
  wrap.scrollIntoView({behavior:'smooth',block:'start'});

  const prompt=`Eres Michael González, entrenador personal con 8 años de experiencia, docente, especialista en recuperación de lesiones, masajes terapéuticos y Zumba. Tu filosofía: salud primero, no estética.

PERFIL DEL CLIENTE:
- Nombre: ${d.nombre}
- Edad: ${d.edad} | Género: ${d.genero} | Plan: ${d.plan}
- Peso: ${d.peso}kg | Talla: ${d.talla}cm | % Grasa: ${d.grasa}
- Medidas: Cintura ${d.cintura}cm | Cadera ${d.cadera}cm

OBJETIVOS:
- Objetivo principal: ${d.objetivo}
- Nivel de actividad: ${d.nivel}
- Días disponibles: ${d.dias} | Tiempo por sesión: ${d.tiempo}
- Equipamiento: ${d.equipo}

SALUD:
- Condiciones médicas: ${d.condiciones}
- Lesiones: ${d.lesiones}
- Medicamentos: ${d.medicamentos}
- Observaciones: ${d.obsSalud}

ALIMENTACIÓN:
- Comidas al día: ${d.comidas} | Tipo de dieta: ${d.dieta}
- No consume: ${d.nocome} | Agua: ${d.agua}
- Observaciones: ${d.obsAli}

NOTAS ADICIONALES: ${d.notas}

Genera un plan completo y profesional en español con estas secciones:
1. RESUMEN DEL PERFIL - análisis breve del cliente
2. OBJETIVOS SMART - 3 objetivos específicos y medibles para 8-12 semanas
3. RUTINA SEMANAL - tabla con días, grupos musculares, ejercicios (con series x reps), descanso. Adapta SIEMPRE a las condiciones médicas y lesiones
4. PROTOCOLO DE RECUPERACIÓN - estiramientos post-entreno y técnicas de recuperación
5. PLAN NUTRICIONAL BÁSICO - calorías estimadas, macros, distribución de comidas, alimentos recomendados y a evitar
6. PROGRESIÓN - cómo evoluciona el plan semana a semana
7. INDICADORES DE SEGUIMIENTO - qué medir y cuándo
8. NOTAS ESPECIALES DEL ENTRENADOR - consejos personalizados de Michael

Usa formato claro con emojis, tablas donde ayude. Sé específico y profesional.`;

  try{
    const resp=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:2000,
        messages:[{role:'user',content:prompt}]
      })
    });
    const data=await resp.json();
    const text=data.content?.[0]?.text||'Error al generar el plan';
    loading.style.display='none';
    body.innerHTML=formatOutput(text,d.nombre);
    window._planText=text;
    btn.disabled=false;btn.textContent='✨ Generar nuevo plan';
  }catch(e){
    loading.style.display='none';
    body.innerHTML=`<div style="color:#E53E3E;font-size:12px">❌ Error de conexión. Verifica tu API key de Anthropic.</div>`;
    btn.disabled=false;btn.textContent='✨ Generar plan con IA';
  }
}

function formatOutput(text,nombre){
  let html=text
    .replace(/^# (.+)$/gm,'<h2>$1</h2>')
    .replace(/^## (.+)$/gm,'<h3>$1</h3>')
    .replace(/^### (.+)$/gm,'<h3 style="font-size:10px;color:var(--v4)">$1</h3>')
    .replace(/\*\*(.+?)\*\*/g,'<strong style="color:var(--v4);font-weight:600">$1</strong>')
    .replace(/^- (.+)$/gm,'<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/gs,'<ul>$&</ul>')
    .replace(/\n\n/g,'<br><br>')
    .replace(/\n/g,'<br>');
  return `<div style="padding:8px 0"><div style="background:rgba(45,106,79,.1);border:1px solid rgba(116,198,157,.2);border-radius:3px;padding:12px 16px;margin-bottom:20px;font-size:11px;color:var(--v4)">✅ Plan generado para <strong>${nombre}</strong> — ${new Date().toLocaleDateString('es-CO',{day:'numeric',month:'long',year:'numeric'})}</div>${html}</div>`;
}

function copyPlan(){
  if(window._planText){
    navigator.clipboard.writeText(window._planText).then(()=>alert('Plan copiado al portapapeles'));
  }
}
function downloadPlan(){
  if(window._planText){
    const nombre=document.getElementById('f-nombre').value||'cliente';
    const blob=new Blob([window._planText],{type:'text/plain'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download=`Plan_${nombre.replace(/\s+/g,'_')}.txt`;
    a.click();
  }
}
</script>
</body>
</html>
