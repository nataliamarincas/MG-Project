    grasa: document.getElementById('f-grasa').value||'No indicado',
    cintura: document.getElementById('f-cintura').value||'No indicado',
    cadera: document.getElementById('f-cadera').value||'No indicado',
    objetivo: getSelectedChips('chips-objetivo')||'No especificado',
    nivel: document.getElementById('f-nivel').value||'N/A',
    dias: getSelectedChips('chips-dias')||'No especificado',
    tiempo: document.getElementById('f-tiempo').value+'min',
